---
import ResourceListPage from '@components/resources/ResourceListPage.astro';
import { getCollection } from 'astro:content';
import siteJson from '@data/site.json';
import { siteSchema } from '@utils/siteSchema';

const site = siteSchema.parse(siteJson);
const resources = (await getCollection('resources'))
  .filter((resource) => resource.data.status === 'published' && resource.data.category === 'lsa-events')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<ResourceListPage
  site={site}
  title="Events"
  eyebrow="LSA Events"
  description="LSA meetings, educational activities, and society events in one place."
  canonicalPath="/events/"
  resources={resources}
  showEventTiming
/>
