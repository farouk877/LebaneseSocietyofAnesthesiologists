---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import siteJson from '@data/site.json';
import { siteSchema } from '@utils/siteSchema';
import SiteFooter from '@components/layout/SiteFooter.astro';
import SiteHeader from '@components/layout/SiteHeader.astro';
import { withBase } from '@utils/paths';

const site = siteSchema.parse(siteJson);

const boardMembers = (await getCollection('board'))
  .filter((member) => member.data.active)
  .sort((a, b) => a.data.order - b.data.order || a.data.name.localeCompare(b.data.name));

const getBioParagraphs = (body: string) =>
  body
    .trim()
    .split(/\n{2,}/)
    .map((paragraph) => paragraph.trim())
    .filter(Boolean);

const resourceSections = [
  {
    label: 'Guidelines',
    href: withBase('/guidelines/'),
    description: 'Clinical guidance and practice resources curated for anesthesiology professionals.'
  },
  {
    label: 'Events',
    href: withBase('/events/'),
    description: 'LSA meetings, educational activities, and society events in one place.'
  },
  {
    label: 'University Resources',
    href: withBase('/university-resources/'),
    description: 'Academic and institutional teaching resources for trainees and faculty.'
  },
  {
    label: 'Articles',
    href: withBase('/articles/'),
    description: 'Articles of the Month, with each selected article available on its own page.'
  }
];
---

<BaseLayout
  title={site.seo.title}
  description={site.seo.description}
  canonicalUrl={site.seo.canonicalUrl}
  socialImage={site.seo.socialImage}
>
  <SiteHeader site={site} home />

  <main id="top" class="bg-lsa-paper pt-[68px]">
    <section class="relative isolate min-h-[calc(100vh-68px)] overflow-hidden bg-lsa-forest">
      <img
        src={withBase(site.hero.image)}
        alt={site.hero.imageAlt}
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-lsa-forest via-lsa-forest/88 to-lsa-forest/20"></div>
      <div class="relative mx-auto flex min-h-[calc(100vh-68px)] max-w-7xl items-center px-4 py-16 sm:px-6 lg:px-8">
        <div class="max-w-[20rem] sm:max-w-3xl">
          <p class="font-sans text-sm font-semibold uppercase tracking-[0.18em] text-lsa-sage">
            {site.hero.eyebrow}
          </p>
          <h1 class="mt-5 text-4xl leading-[1.06] text-white sm:text-6xl lg:text-7xl">
            {site.hero.heading}
          </h1>
          <p class="mt-6 max-w-[20rem] font-sans text-base leading-7 text-lsa-sage sm:max-w-2xl sm:text-xl sm:leading-8">
            {site.hero.subheading}
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <a
              href={withBase(site.hero.primaryCta.href)}
              class="rounded-md bg-lsa-leaf px-5 py-3 font-sans text-sm font-semibold text-white no-underline shadow-soft transition hover:bg-lsa-green"
            >
              {site.hero.primaryCta.label}
            </a>
            {site.hero.secondaryCta && (
              <a
                href={withBase(site.hero.secondaryCta.href)}
                class="rounded-md border border-white/35 bg-white/10 px-5 py-3 font-sans text-sm font-semibold text-white no-underline backdrop-blur transition hover:bg-white/20"
              >
                {site.hero.secondaryCta.label}
              </a>
            )}
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="bg-white scroll-mt-24">
      <div class="mx-auto grid max-w-7xl gap-12 px-4 py-20 sm:px-6 lg:grid-cols-[0.8fr_1.2fr] lg:px-8">
        <div>
          <p class="font-sans text-sm font-semibold uppercase tracking-[0.16em] text-lsa-green">{site.about.eyebrow}</p>
          <h2 class="mt-4 text-4xl leading-tight text-lsa-forest sm:text-5xl">{site.about.heading}</h2>
        </div>
        <div class="space-y-6 text-lg leading-8 text-lsa-muted">
          {site.about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          <div class="grid gap-4 sm:grid-cols-3">
            {site.about.milestones.map((milestone) => (
              <div class="rounded-md border border-lsa-line bg-lsa-paper p-5">
                <p class="font-sans text-xs font-bold uppercase tracking-[0.14em] text-lsa-copper">{milestone.title}</p>
                <p class="mt-3 text-sm leading-6 text-lsa-muted">{milestone.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="mission" class="scroll-mt-24 border-y border-lsa-line bg-lsa-mist">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 py-20 sm:px-6 lg:grid-cols-[0.92fr_1.08fr] lg:px-8">
        <div>
          <p class="font-sans text-sm font-semibold uppercase tracking-[0.16em] text-lsa-green">{site.presidentMessage.eyebrow}</p>
          {site.presidentMessage.heading && <h2 class="mt-4 text-4xl leading-tight text-lsa-forest sm:text-5xl">{site.presidentMessage.heading}</h2>}
          <div class:list={['overflow-hidden rounded-md border border-lsa-line bg-white shadow-soft', site.presidentMessage.heading ? 'mt-8' : 'mt-5']}>
            <img
              src={withBase(site.presidentMessage.image)}
              alt={site.presidentMessage.imageAlt}
              class="aspect-[4/5] w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <article class="rounded-md border border-lsa-line bg-white p-6 shadow-soft sm:p-8">
          <div class="space-y-5 font-sans text-base leading-8 text-lsa-muted">
            {site.presidentMessage.body.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
          <div class="mt-8 border-t border-lsa-line pt-5">
            <p class="text-2xl leading-tight text-lsa-forest">{site.presidentMessage.signerName}</p>
            {site.presidentMessage.signerTitle && (
              <p class="mt-2 font-sans text-sm font-semibold text-lsa-green">{site.presidentMessage.signerTitle}</p>
            )}
          </div>
        </article>
      </div>
    </section>

    <section id="board" class="scroll-mt-24 bg-white">
      <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
          <div class="max-w-3xl">
            <p class="font-sans text-sm font-semibold uppercase tracking-[0.16em] text-lsa-green">{site.board.eyebrow}</p>
            <h2 class="mt-4 text-4xl leading-tight text-lsa-forest sm:text-5xl">{site.board.heading}</h2>
          </div>
          {site.board.intro && (
            <p class="max-w-md font-sans text-sm leading-6 text-lsa-muted">
              {site.board.intro}
            </p>
          )}
        </div>
        <div class="mt-10 grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
          {boardMembers.map((member) => {
            const bioParagraphs = getBioParagraphs(member.body || '');
            const preview = bioParagraphs[0];
            const dialogId = `bio-${member.id}`;

            return (
              <article class="flex rounded-md border border-lsa-line bg-lsa-paper p-5">
                <div class="flex w-full flex-col">
                  {member.data.photo ? (
                    <img src={withBase(member.data.photo)} alt={member.data.photoAlt || member.data.name} class="aspect-[4/5] w-full rounded-md object-cover" loading="lazy" />
                  ) : (
                    <div class="aspect-[4/5] rounded-md bg-gradient-to-br from-lsa-sage via-white to-lsa-mist"></div>
                  )}
                  <p class="mt-5 font-sans text-xs font-bold uppercase tracking-[0.14em] text-lsa-copper">{member.data.role}</p>
                  <h3 class="mt-2 text-2xl text-lsa-forest">{member.data.name}</h3>
                  {member.data.specialty && <p class="mt-2 font-sans text-sm font-semibold text-lsa-forest">{member.data.specialty}</p>}
                  {member.data.institution && <p class="mt-1 font-sans text-sm leading-6 text-lsa-muted">{member.data.institution}</p>}
                  {preview && <p class="mt-4 flex-1 font-sans text-sm leading-7 text-lsa-muted">{preview}</p>}
                  {bioParagraphs.length > 0 && (
                    <button
                      type="button"
                      class="mt-3 w-fit font-sans text-sm font-semibold text-lsa-green underline"
                      data-bio-open={dialogId}
                      aria-controls={dialogId}
                    >
                      Read full bio
                    </button>
                  )}
                  <dialog id={dialogId} class="board-bio-dialog max-h-[90vh] w-[min(92vw,760px)] rounded-md border border-lsa-line bg-white p-0 text-lsa-ink shadow-soft">
                    <div class="max-h-[90vh] overflow-y-auto p-6 sm:p-8">
                      <div class="flex items-start justify-between gap-6">
                        <div>
                          <p class="font-sans text-xs font-bold uppercase tracking-[0.14em] text-lsa-copper">{member.data.role}</p>
                          <h4 class="mt-2 text-3xl leading-tight text-lsa-forest">{member.data.name}</h4>
                          {member.data.specialty && <p class="mt-2 font-sans text-sm font-semibold text-lsa-green">{member.data.specialty}</p>}
                        </div>
                        <button type="button" class="rounded-md border border-lsa-line px-3 py-2 font-sans text-sm font-semibold text-lsa-forest" data-bio-close>
                          Close
                        </button>
                      </div>
                      {member.data.institution && <p class="mt-4 font-sans text-sm leading-6 text-lsa-muted">{member.data.institution}</p>}
                      <div class="mt-6 space-y-5 font-sans text-base leading-8 text-lsa-muted">
                        {bioParagraphs.map((paragraph) => <p>{paragraph}</p>)}
                      </div>
                      <div class="mt-6 flex flex-wrap items-center gap-4 border-t border-lsa-line pt-5 font-sans text-sm font-semibold">
                        {member.data.email && <a href={`mailto:${member.data.email}`} class="text-lsa-green underline">Email</a>}
                        {member.data.linkedinUrl && <a href={member.data.linkedinUrl} target="_blank" rel="noreferrer" class="text-lsa-green underline">LinkedIn</a>}
                      </div>
                    </div>
                  </dialog>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section id="resources" class="scroll-mt-24 border-y border-lsa-line bg-lsa-paper">
      <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="font-sans text-sm font-semibold uppercase tracking-[0.16em] text-lsa-green">{site.resources.eyebrow}</p>
          {site.resources.heading && <h2 class="mt-4 text-4xl leading-tight text-lsa-forest sm:text-5xl">{site.resources.heading}</h2>}
          {site.resources.intro && <p class="mt-5 max-w-2xl font-sans text-base leading-8 text-lsa-muted">{site.resources.intro}</p>}
        </div>
        <div class="mt-10 grid grid-cols-2 gap-3 md:gap-5 xl:grid-cols-4">
          {resourceSections.map((section) => (
            <a href={section.href} class="flex min-h-[170px] flex-col rounded-md border border-lsa-line bg-white p-4 no-underline shadow-soft transition hover:border-lsa-green sm:min-h-[210px] sm:p-6">
              <h3 class="text-xl leading-tight text-lsa-forest sm:text-2xl">{section.label}</h3>
              <p class="mt-3 flex-1 font-sans text-xs leading-6 text-lsa-muted sm:mt-4 sm:text-sm sm:leading-7">{section.description}</p>
              <span class="mt-4 font-sans text-xs font-semibold text-lsa-green sm:mt-6 sm:text-sm">View {section.label}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="mailing-list" class="scroll-mt-24 bg-lsa-forest">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 py-20 text-white sm:px-6 lg:grid-cols-[1fr_0.9fr] lg:px-8">
        <div>
          <p class="font-sans text-sm font-semibold uppercase tracking-[0.16em] text-lsa-sage">{site.mailingList.eyebrow}</p>
          <h2 class="mt-4 text-4xl leading-tight sm:text-5xl">{site.mailingList.heading}</h2>
          <p class="mt-5 max-w-2xl font-sans text-base leading-8 text-lsa-sage">
            {site.mailingList.description}
          </p>
        </div>
        <form
          class="mailing-shell relative rounded-md border border-white/15 bg-white p-5 text-lsa-ink shadow-soft"
          data-endpoint={site.mailingList.endpoint}
          data-success-message={site.mailingList.successMessage}
          data-error-message={site.mailingList.errorMessage}
          data-configuration-message={site.mailingList.configurationMessage}
          novalidate
        >
          <label for="email" class="font-sans text-sm font-semibold text-lsa-forest">Email address</label>
          <div class="absolute left-[-9999px] top-auto h-px w-px overflow-hidden" aria-hidden="true">
            <label for="website">Website</label>
            <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
          </div>
          <div class="mt-3 flex flex-col gap-3 sm:flex-row">
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              required
              placeholder={site.mailingList.placeholderEmail}
              class="min-h-12 flex-1 rounded-md border border-lsa-line px-4 font-sans text-base"
            />
            <button type="submit" class="min-h-12 rounded-md bg-lsa-green px-5 font-sans text-sm font-semibold text-white transition hover:bg-lsa-forest">
              {site.mailingList.buttonLabel}
            </button>
          </div>
          <label class="mt-4 flex gap-3 font-sans text-sm leading-6 text-lsa-muted">
            <input
              id="mailing-consent"
              name="consent"
              type="checkbox"
              required
              class="mt-1 h-4 w-4 rounded border-lsa-line text-lsa-green"
            />
            <span>{site.mailingList.consentLabel}</span>
          </label>
          <p class="mailing-shell-status mt-3 min-h-6 font-sans text-sm text-lsa-muted" role="status" aria-live="polite"></p>
        </form>
      </div>
    </section>
  </main>

  <SiteFooter site={site} />

  <script>
    const bioOpenButtons = document.querySelectorAll<HTMLButtonElement>('[data-bio-open]');
    const bioDialogs = document.querySelectorAll<HTMLDialogElement>('.board-bio-dialog');

    bioOpenButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const dialogId = button.dataset.bioOpen;
        const dialog = dialogId ? document.getElementById(dialogId) as HTMLDialogElement | null : null;
        dialog?.showModal();
      });
    });

    bioDialogs.forEach((dialog) => {
      dialog.querySelectorAll<HTMLButtonElement>('[data-bio-close]').forEach((button) => {
        button.addEventListener('click', () => dialog.close());
      });

      dialog.addEventListener('click', (event) => {
        if (event.target === dialog) {
          dialog.close();
        }
      });
    });

    const mailingForm = document.querySelector<HTMLFormElement>('.mailing-shell');
    const mailingStatus = document.querySelector<HTMLElement>('.mailing-shell-status');
    const mailingButton = mailingForm?.querySelector<HTMLButtonElement>('button[type="submit"]');
    const mailingEmail = mailingForm?.querySelector<HTMLInputElement>('input[name="email"]');
    const mailingConsent = mailingForm?.querySelector<HTMLInputElement>('input[name="consent"]');
    const mailingHoneypot = mailingForm?.querySelector<HTMLInputElement>('input[name="website"]');

    const setMailingStatus = (message: string) => {
      if (mailingStatus) {
        mailingStatus.textContent = message;
      }
    };

    mailingForm?.addEventListener('submit', async (event) => {
      event.preventDefault();

      const endpoint = mailingForm.dataset.endpoint;
      if (!endpoint) {
        setMailingStatus(mailingForm.dataset.configurationMessage || 'Mailing-list signup is not connected yet.');
        return;
      }

      if (!mailingEmail?.validity.valid) {
        setMailingStatus('Enter a valid email address.');
        mailingEmail?.focus();
        return;
      }

      if (!mailingConsent?.checked) {
        setMailingStatus('Please confirm consent to join the mailing list.');
        mailingConsent?.focus();
        return;
      }

      const body = new URLSearchParams({
        email: mailingEmail.value,
        consent: 'true',
        source: 'lsa-website',
        website: mailingHoneypot?.value || ''
      });

      mailingButton?.setAttribute('disabled', 'true');
      setMailingStatus('Submitting...');

      try {
        const response = await fetch(endpoint, {
          method: 'POST',
          body
        });
        const payload = await response.json().catch(() => null);

        if (!response.ok || payload?.ok === false) {
          throw new Error(payload?.error || 'submission_failed');
        }

        mailingForm.reset();
        setMailingStatus(mailingForm.dataset.successMessage || 'Thank you. Your email has been submitted.');
      } catch {
        setMailingStatus(mailingForm.dataset.errorMessage || 'We could not submit your email right now. Please try again later.');
      } finally {
        mailingButton?.removeAttribute('disabled');
      }
    });
  </script>
</BaseLayout>
