---
import ResourceListPage from '@components/resources/ResourceListPage.astro';
import { getCollection } from 'astro:content';
import siteJson from '@data/site.json';
import { siteSchema } from '@utils/siteSchema';

const site = siteSchema.parse(siteJson);
const resources = (await getCollection('resources'))
  .filter((resource) => resource.data.status === 'published' && resource.data.category === 'guidelines')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<ResourceListPage
  site={site}
  title="Guidelines"
  eyebrow="Guidelines"
  description="Clinical guidance and practice resources curated for anesthesiology professionals."
  canonicalPath="/guidelines/"
  resources={resources}
/>
